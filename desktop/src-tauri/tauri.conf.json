{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Scrible",
  "version": "0.1.0",
  "identifier": "com.scrible.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Scrible",
        "width": 400,
        "height": 580,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon128.png"]
  }
}
