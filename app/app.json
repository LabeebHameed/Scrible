{
  "expo": {
    "name": "Scrible",
    "slug": "scrible",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "scrible",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0E0F13",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.scrible.app",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Scrible transcribes your voice on this device to create tasks, ideas, and reminders.",
        "NSMicrophoneUsageDescription": "Scrible uses the microphone so you can capture tasks, ideas, and reminders by speaking."
      }
    },
    "android": {
      "package": "com.scrible.app",
      "edgeToEdgeEnabled": true,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.USE_FULL_SCREEN_INTENT",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-status-bar",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Scrible uses the microphone so you can capture tasks, ideas, and reminders by speaking.",
          "speechRecognitionPermission": "Scrible transcribes your voice on this device to create tasks, ideas, and reminders."
        }
      ],
      "expo-notifications",
      "react-native-notify-kit",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "ScribleCapture",
              "label": "Scrible — Voice Capture",
              "description": "Tap to capture a thought by voice",
              "minWidth": "80dp",
              "minHeight": "80dp",
              "targetCellWidth": 2,
              "targetCellHeight": 1,
              "resizeMode": "none",
              "updatePeriodMillis": 0
            }
          ]
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "08a730b6-405c-4c01-a387-9259e835b6df"
      }
    },
    "owner": "labeeb_hameed"
  }
}
